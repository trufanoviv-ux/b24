# Full incoming webhook base URL from Bitrix24.
# Put the real value into Render environment variables, not into git.
BITRIX24_WEBHOOK_URL=

# Optional: set to true to include raw Bitrix responses in tool output.
BITRIX24_DEBUG=false

# Strongly recommended for public Render deployment.
# Clients must send: Authorization: Bearer <this value>
MCP_AUTH_TOKEN=
